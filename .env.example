# CloudAnzen Environment Variables
# Copy to .env.local for local development

# Next.js
NEXT_PUBLIC_APP_URL=https://www.cloudanzen.com

# CloudAnzen Academy — public API origin (see Cloudanzen-backend public-academy module).
# Used server-side to fetch course content + verify certificates; exposed to the
# client for the course player so the browser can call /score and /certificates.
NEXT_PUBLIC_BACKEND_URL=https://api.cloudanzen.com
# Cloudflare Turnstile site key (server-side secret lives in the backend env).
# Leave blank in dev — backend short-circuits captcha verification.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# (Optional) Add your actual keys below when integrating forms/analytics
# RESEND_API_KEY=
# NEXT_PUBLIC_POSTHOG_KEY=
